@page "/report"
@inject DataSource Data

<Nav ShowHome="true" Title="Report" />

<div class="page-toolbar report-toolbar">
    <div class="surface-card report-toolbar__panel">
        <div class="report-toolbar__copy">
            <p class="report-toolbar__eyebrow">PDF export</p>
            <h4>Generate polished year-by-year report packs</h4>
            <p>Exports one PDF per report tab, with the summary view first and the contributing transactions on the following pages.</p>
        </div>

        @if (HasOpen)
        {
            <div class="report-toolbar__controls">
                <label class="report-control">
                    <span>Open position sell price</span>
                    <WhileTypingInputText @bind-Value="SellPrice" />
                </label>

                <label class="report-control report-control--currency">
                    <span>Currency</span>
                    <InputSelect @bind-Value="Currency">
                        <option>USD</option>
                        <option>AUD</option>
                    </InputSelect>
                </label>
            </div>
        }
    </div>

    <div class="report-toolbar__actions">
        <Button @onclick="ExportPdf_Click">Export PDFs</Button>
    </div>
</div>

<MudBlazor.MudTabs>
    @if (HasOpen)
    {
        <MudBlazor.MudTabPanel Text="Open">
            <CgtSingleYearReport Report="_report.Open" />
        </MudBlazor.MudTabPanel>
    }
    @foreach (var report in _report.Reports)
    {
        <MudBlazor.MudTabPanel Text="@report.TaxYear">
            <CgtSingleYearReport Report="report" />
        </MudBlazor.MudTabPanel>
    }
</MudBlazor.MudTabs>

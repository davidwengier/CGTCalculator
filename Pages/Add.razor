@page "/add"
@page "/edit/{id:guid}"

@inject DataSource DataSource
@inject NavigationManager NavigationManager

<Nav ShowHome="false" Title="@(IsAdd ? "Add Transaction" : "Edit Transaction")" />

<div class="editor-shell">
    <section class="surface-card editor-card">
        <div class="editor-card__intro">
            <p class="editor-card__eyebrow">Transaction details</p>
            <h4>@(IsAdd ? "Capture the next transaction quickly" : "Update the selected transaction")</h4>
            <p>
                @(IsAdd
                    ? "Date and symbol carry forward from the last transaction you added, and the symbol field also lets you choose from symbols already in the database."
                    : "Adjust any of the transaction details below, then save when you're ready.")
            </p>
        </div>

        <div class="editor-form-grid">
            <label class="field field--wide">
                <span>Symbol</span>
                <SymbolInput @bind-Value="_model.Symbol"
                             Symbols="_symbols"
                             placeholder="Start typing or pick an existing symbol" />
            </label>

            <label class="field">
                <span>Date</span>
                <InputDate @bind-Value="_model.Date" />
            </label>

            <label class="field">
                <span>Type</span>
                <InputSelect @bind-Value="_model.Type">
                    @foreach (var item in Enum.GetValues<TransactionType>())
                    {
                        <option value="@item">@item.ToString()</option>
                    }
                </InputSelect>
            </label>

            <label class="field">
                <span>Quantity</span>
                <InputNumber @bind-Value="_model.Quantity" />
            </label>

            <label class="field">
                <span>Total Value</span>
                <InputNumber @bind-Value="_model.Value" />
            </label>
        </div>

        <div class="page-actions">
            <Button @onclick="Add_Click">@(IsAdd ? "Add" : "Save")</Button>
            <Button @onclick="Cancel_Click">Cancel</Button>
        </div>
    </section>
</div>
